      "manifest": {
        "lifecycle": "active",
        "name": "agentpantry",
        "schema": "brigade.station.v1",
        "station": "pantry",
        "summary": "browser session auth sync through a process-boundary Go binary",
        "tools": [
          {
            "command": "agentpantry",
            "install": [
              "go",
              "install",
              "github.com/escoffier-labs/agentpantry/cmd/agentpantry@latest"
            ],
            "kind": "executable",
            "name": "agentpantry",
            "summary": "browser session auth sync from source to sink",
            "surfaces": [
              {
                "command": [
                  "agentpantry",
                  "doctor",
                  "--json",
                  "--no-net"
                ],
                "kind": "doctor-json",
                "probe": [
                  "agentpantry",
                  "doctor",
                  "--help"
                ],
                "probe_contains": [
                  "-json",
                  "-no-net"
                ],
                "read_only": false,
                "timeout_seconds": 10
              },
              {
                "command": [
                  "agentpantry",
                  "inventory",
                  "--json"
                ],
                "kind": "summary-json",
                "max_chars": 4000,
                "probe": [
                  "agentpantry",
                  "inventory",
                  "--help"
                ],
                "probe_contains": [
                  "-json"
                ],
                "read_only": true,
                "timeout_seconds": 10
              },
              {
                "command": [
                  "agentpantry",
                  "version",
                  "--json"
                ],
                "kind": "verify-exit",
                "read_only": true,
                "timeout_seconds": 10
              }
            ]
          }
        ]
      },

[9.58, "o", "local_only:\r\n"]
[9.64, "o", "- .brigade/ stores local config, receipts, scans, reports, waivers, and run artifacts.\r\n"]
[9.7, "o", "- Brigade does not run automatically, start daemons, activate hooks, send notifications, publish, push, tag, or mutate remotes.\r\n"]
